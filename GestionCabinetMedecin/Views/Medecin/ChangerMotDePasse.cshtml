@model GestionCabinetMedecin.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Changer mot de passe";
}

<h2>Changer mon mot de passe</h2>

@if (ViewBag.Success != null)
{
    <div class="alert alert-success">
        @ViewBag.Success
    </div>
}

<form asp-action="ChangerMotDePasse" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- Ancien mot de passe -->
    <div class="mb-3">
        <label asp-for="OldPassword" class="form-label">Ancien mot de passe</label>
        <input asp-for="OldPassword" class="form-control" />
        <span asp-validation-for="OldPassword" class="text-danger"></span>
    </div>

    <!-- Nouveau mot de passe -->
    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label">Nouveau mot de passe</label>
        <input asp-for="NewPassword" class="form-control" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>

    <!-- Confirmation -->
    <div class="mb-3">
        <label asp-for="ConfirmNewPassword" class="form-label">Confirmer le nouveau mot de passe</label>
        <input asp-for="ConfirmNewPassword" class="form-control" />
        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Changer le mot de passe</button>
    <a asp-action="MonCompte" class="btn btn-secondary">Retour</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
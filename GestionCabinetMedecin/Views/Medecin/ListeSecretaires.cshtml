@model IEnumerable<GestionCabinetMedecin.Models.ApplicationUser>

@{
    ViewData["Title"] = "Liste des Secrétaires";
}

<h2>Liste des Secrétaires</h2>

<p>
    <a asp-action="AjouterSecretaire" class="btn btn-success">Ajouter une secrétaire</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var secretaire in Model)
        {
            <tr>
                <td>@secretaire.Nom</td>
                <td>@secretaire.Prenom</td>
                <td>@secretaire.Email</td>
                <td>@secretaire.PhoneNumber</td>
                <td>
                    <a asp-action="ModifierSecretaire" asp-route-id="@secretaire.Id" class="btn btn-warning btn-sm">Modifier</a>
                    <a asp-action="SupprimerSecretaire" asp-route-id="@secretaire.Id" class="btn btn-danger btn-sm">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>
@model GestionCabinetMedecin.Models.ApplicationUser

@{
    ViewData["Title"] = "Supprimer Secrétaire";
}

<h2>Supprimer une Secrétaire</h2>

<div class="alert alert-warning">
    Êtes-vous sûr de vouloir supprimer ce compte ?
</div>

<div>
    <p><strong>Nom :</strong> @Model.Nom</p>
    <p><strong>Prénom :</strong> @Model.Prenom</p>
    <p><strong>Email :</strong> @Model.Email</p>
</div>

<form asp-action="SupprimerSecretaire" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="ListeSecretaires" class="btn btn-secondary">Annuler</a>
</form>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GestionCabinetMedecin</title>

    <!-- Import des styles Bootstrap et CSS du projet -->
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GestionCabinetMedecin.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">

                <!-- Nom du projet / logo texte -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GestionCabinetMedecin</a>

                <!-- Bouton responsive pour petit écran -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Contenu de la navbar -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- Liens de navigation à gauche -->
                    <ul class="navbar-nav flex-grow-1">

                        <!-- Lien Home -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <!-- Lien Privacy -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        <!-- Liens visibles uniquement si l'utilisateur connecté est un médecin -->
                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Medecin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Medecin" asp-action="MonCompte">Mon compte</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Medecin" asp-action="ListeSecretaires">Secrétaires</a>
                            </li>
                        }
                    </ul>

                    <!-- Zone utilisateur à droite :
                         - si connecté : afficher le nom + bouton Déconnexion
                         - sinon : afficher le lien Connexion -->
                    <div class="d-flex align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <span class="me-3">
                                Bonjour @User.Identity.Name
                            </span>

                            <a class="btn btn-outline-danger btn-sm"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                Déconnexion
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary btn-sm"
                                   asp-controller="Account"
                                   asp-action="Login">
                                Connexion
                            </a>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- Contenu principal de chaque page -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Pied de page -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GestionCabinetMedecin - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Scripts JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
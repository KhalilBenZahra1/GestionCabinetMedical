@model GestionCabinetMedecin.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Connexion";
}

<h2>Connexion</h2>

<!--
    Formulaire de connexion :
    - Email
    - Mot de passe
    - Rôle
-->
<form asp-action="Login" method="post">
    
    <!-- Affiche les erreurs globales -->
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- Champ Email -->
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <!-- Champ MotDePasse -->
    <div class="mb-3">
        <label asp-for="MotDePasse" class="form-label"></label>
        <input asp-for="MotDePasse" class="form-control" />
        <span asp-validation-for="MotDePasse" class="text-danger"></span>
    </div>

    <!-- Liste déroulante pour choisir le rôle -->
    <div class="mb-3">
        <label asp-for="Role" class="form-label"></label>
        <select asp-for="Role" class="form-control">
            <option value="">-- Choisir un rôle --</option>
            <option value="Medecin">Médecin</option>
            <option value="Secretaire">Secrétaire</option>
        </select>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>

    <!-- Bouton de connexion -->
    <button type="submit" class="btn btn-primary">Se connecter</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}